<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="30" xmlns:fx="http://javafx.com/fxml"
      fx:controller="proyect_batalla_naval.controller.WelcomeController"
      style="-fx-background-color: #1a1a2e;" prefWidth="500" prefHeight="400">
    <padding>
        <Insets bottom="40" left="40" right="40" top="40"/>
    </padding>

    <Label text="⚓ BATALLA NAVAL ⚓"
           style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
    <Label text="Juego de Estrategia Naval"
           style="-fx-font-size: 16; -fx-text-fill: #8888aa;"/>

    <VBox spacing="10" alignment="CENTER" maxWidth="300">
        <Label text="Ingresa tu nickname:"
               style="-fx-text-fill: #c0c0c0; -fx-font-size: 14;"/>
        <TextField fx:id="nicknameField" promptText="Tu nombre..."
                   style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #666; -fx-padding: 10; -fx-font-size: 14;"/>
    </VBox>

    <Button fx:id="playButton" text="▶ JUGAR" onAction="#onPlayClicked"
            style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-font-size: 16; -fx-padding: 12 40; -fx-cursor: hand;"/>

    <Label fx:id="errorLabel" text=""
           style="-fx-text-fill: #e74c3c; -fx-font-size: 12;"/>
</VBox>
